{
    "manifest_version": 3,
    "name": "Shrinkr",
    "version": "1.0.0",
    "description": "Efficient file compression extension for Text, Images, Audio, and Video.",
    "action": {
        "default_popup": "popup.html",
        "default_title": "Open Shrinkr"
    },
    "host_permissions": [
        "<all_urls>"
    ],
    "permissions": [
        "storage"
    ],
    "cross_origin_embedder_policy": {
        "value": "require-corp"
    },
    "cross_origin_opener_policy": {
        "value": "same-origin"
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
    }
}